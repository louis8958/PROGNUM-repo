   "source": [
    "Y = float(input(\"The year of birth is \"))\n",
    "M = float(input(\"The month of birth is \"))\n",
    "D = float(input(\"The day of birth is \"))\n",
    "\n",
    "JD = 367*Y -7*(Y+(M+9)/12)/4 - 3*((Y+(M-9)/7)/100 + 1)/4 + (275*M)/9 + D + 1721029-0.5\n",
    "print(f'The Julian Date is {JD}')"
   ]
